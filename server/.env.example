# Copy to `.env` and adjust. All values are optional; sensible defaults apply.

# HTTP listener
SSP_HOST=0.0.0.0
SSP_PORT=8080

# Where the panel keeps its SQLite DB and runtime data
SSP_DATA_DIR=./data

# 32-byte key (base64 or hex) used to encrypt stored remote-server credentials
# at rest. Generate: `openssl rand -base64 32`. Required once M6 lands; may be
# left unset during early milestones.
# SSP_SECRET_KEY=

# First-run admin bootstrap. On an empty database the panel creates one admin
# account. Set a password here to control it; otherwise a random one is
# generated and printed to the log once at startup.
SSP_ADMIN_USERNAME=admin
# SSP_ADMIN_PASSWORD=

# node env: development | production
# NOTE: session cookies get the Secure flag in production, so production must be
# served over HTTPS (behind a TLS-terminating reverse proxy).
NODE_ENV=development
